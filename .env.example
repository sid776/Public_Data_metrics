# Optional: Use OpenAI for embeddings and/or LLM responses (better quality, requires API key)
# OPENAI_API_KEY=sk-...

# Optional: Override embedding model (default: local sentence-transformers)
# EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB persistence directory (default: ./data/chroma)
# CHROMA_PERSIST_DIR=./data/chroma

# MLflow tracking (default: local ./mlruns)
# MLFLOW_TRACKING_URI=./mlruns
